// Per-process resource allocations and executor profiles.
// Sized against a standard input SMRT cell raw HiFi BAM (~65 GB, m84094_260226_200655_s1.hifi_reads.*.bam).
// No generic process_low/medium/high/ultra tiers — every process gets its own allocation
// based on what it actually does to that BAM (or its downstream derivatives).

profiles {
    standard {
        process.executor = 'local'
    }

    slurm {
        process.queue          = 'compute'
        apptainer.envWhitelist = ['APPTAINER_TMPDIR', 'APPTAINER_CACHEDIR']
        apptainer.runOptions   = '--bind /charite-store-f/f-cc12-ag-romagnani,/sc-projects/sc-proj-cc12-ag-romagnani,/sc-scratch/sc-scratch-cc12-ag-romagnani,/home/knighto'

        process {
            errorStrategy = 'terminate'

            // ── COLLECT_INSTRUMENT_STATS ─────────────────────────────────────
            withName: 'COLLECT_INSTRUMENT_STATS' { cpus = 1;  memory = 2.GB;   time = 30.m }

            // ── PREPROCESS: PacBio segmentation / demux (raw ~65 GB ubam) ────
            withName: 'PREPROCESS:SKERA_SPLIT'                { cpus = 16; memory = 32.GB;  time = 12.h }
            withName: 'PREPROCESS:SAMTOOLS_LENGTH_FILTER'     { cpus = 4;  memory = 8.GB;   time = 4.h  }
            withName: 'PREPROCESS:EXTRACT_BAM_HEADER_READS'   { cpus = 1;  memory = 4.GB;   time = 1.h  }
            withName: 'PREPROCESS:DETECT_SAMPLE_INDICES'      { cpus = 1;  memory = 4.GB;   time = 1.h  }
            withName: 'PREPROCESS:CONSTRUCT_MULTIPLEX_PRIMERS' { cpus = 1; memory = 2.GB;   time = 30.m }
            withName: 'PREPROCESS:LIMA_ISOSEQ'                { cpus = 16; memory = 16.GB;  time = 8.h  }
            withName: 'PREPROCESS:LIMA_MULTIPLEX'             { cpus = 16; memory = 16.GB;  time = 8.h  }
            withName: 'PREPROCESS:MERGE_INDEX_BAMS'           { cpus = 8;  memory = 16.GB;  time = 6.h  }
            withName: 'PREPROCESS:ISOSEQ_TAG'                 { cpus = 8;  memory = 16.GB;  time = 6.h  }
            withName: 'PREPROCESS:ISOSEQ_REFINE'              { cpus = 8;  memory = 16.GB;  time = 6.h  }

            // ── PREPROCESS: cramino read-loss funnel (size shrinks at each stage) ─
            withName: 'PREPROCESS:CRAMINO_RAW'             { cpus = 8; memory = 16.GB; time = 6.h }
            withName: 'PREPROCESS:CRAMINO_SEGMENTED'       { cpus = 8; memory = 16.GB; time = 6.h }
            withName: 'PREPROCESS:CRAMINO_LENGTH_FILTERED' { cpus = 4; memory = 8.GB;  time = 4.h }
            withName: 'PREPROCESS:CRAMINO_FULL_LENGTH'     { cpus = 4; memory = 8.GB;  time = 2.h }
            withName: 'PREPROCESS:CRAMINO_TRIMMED'         { cpus = 2; memory = 4.GB;  time = 2.h }

            // ── BARCODE_ALIGN: per-sample merge → barcode correct → dedup → align ─
            withName: 'BARCODE_ALIGN:SAMTOOLS_MERGE_FLTNC' { cpus = 8;  memory = 16.GB; time = 6.h  }
            withName: 'BARCODE_ALIGN:PREPARE_WHITELIST'    { cpus = 1;  memory = 4.GB;  time = 30.m }
            withName: 'BARCODE_ALIGN:ISOSEQ_CORRECT'       { cpus = 16; memory = 32.GB; time = 12.h }
            withName: 'BARCODE_ALIGN:SAMTOOLS_SORT_CB'     { cpus = 8;  memory = 32.GB; time = 8.h  }
            withName: 'BARCODE_ALIGN:ISOSEQ_GROUPDEDUP'    { cpus = 16; memory = 64.GB; time = 16.h }
            withName: 'BARCODE_ALIGN:PBMM2_ALIGN'          { cpus = 16; memory = 64.GB; time = 24.h }
            withName: 'BARCODE_ALIGN:GENERATE_CRAM'        { cpus = 8;  memory = 16.GB; time = 6.h  }
            withName: 'BARCODE_ALIGN:SAMTOOLS_FLAGSTAT'    { cpus = 2;  memory = 4.GB;  time = 2.h  }
            withName: 'BARCODE_ALIGN:CRAMINO_ALIGNED'      { cpus = 4;  memory = 8.GB;  time = 4.h  }

            // ── CLASSIFY: per-library shard split + joint shard discovery ────
            withName: 'CLASSIFY:CB_SUFFIX_INJECT'   { cpus = 8; memory = 16.GB; time = 6.h }
            withName: 'CLASSIFY:SPLIT_BAM_BY_SHARD' { cpus = 4; memory = 8.GB;  time = 2.h }
            // ponytail: each shard is ~1/17th the joint data, downgraded from a process_ultra-style ISOQUANT_DISCOVERY allocation
            withName: 'CLASSIFY:ISOQUANT_DISCOVERY_SHARD' { cpus = 16; memory = 64.GB; time = 12.h }
            withName: 'CLASSIFY:MERGE_SHARD_GTFS'         { cpus = 2;  memory = 8.GB;  time = 1.h  }
            withName: 'CLASSIFY:SQANTI3_SPLIT_GTF'        { cpus = 2;  memory = 4.GB;  time = 30.m }
            // ponytail: ~1/8th the transcripts per chunk, downgraded from full SQANTI3_QC allocation
            withName: 'CLASSIFY:SQANTI3_QC_CHUNK'         { cpus = 8;  memory = 32.GB; time = 6.h  }
            withName: 'CLASSIFY:SQANTI3_MERGE_CHUNKS'     { cpus = 2;  memory = 8.GB;  time = 30.m }
            withName: 'CLASSIFY:SQANTI3_FILTER'           { cpus = 8;  memory = 32.GB; time = 4.h  }
            withName: 'CLASSIFY:SQANTI3_RESCUE'           { cpus = 8;  memory = 32.GB; time = 4.h  }

            // ── Joint isoform discovery / classification (whole experiment, all libraries) ─
            withName: 'ISOQUANT_DISCOVERY' { cpus = 32; memory = 600.GB; time = 48.h }
            withName: 'SQANTI3_QC'         { cpus = 16; memory = 128.GB; time = 24.h }

            // ── QUANTIFY: per-library quantification against filtered GTF ────
            withName: 'QUANTIFY:ISOQUANT_QUANTIFY' { cpus = 16; memory = 96.GB; time = 16.h }

            // ── EXPORT: matrix export, shared catalog, saturation curves ─────
            withName: 'EXPORT:EXPORT_LIBRARY_MTX'      { cpus = 2; memory = 16.GB; time = 2.h }
            withName: 'EXPORT:GENERATE_SHARED_CATALOG' { cpus = 2; memory = 16.GB; time = 2.h }
            withName: 'EXPORT:CALCULATE_SATURATION'    { cpus = 2; memory = 16.GB; time = 2.h }

            // ── MultiQC aggregation ───────────────────────────────────────────
            withName: 'MULTIQC' { cpus = 2; memory = 8.GB; time = 2.h }
        }
    }
}
