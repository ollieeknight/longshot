workDir = '/sc-scratch/sc-scratch-cc12-ag-romagnani/nf_work_longshot'

env {
    APPTAINER_TMPDIR  = '/sc-scratch/sc-scratch-cc12-ag-romagnani/nf_work_longshot'
    APPTAINER_CACHEDIR = '/home/knighto/bin/apptainer/cache'
}

params {
    // ── Input / output ──────────────────────────────────────────────────────────
    samplesheet = null
    outdir      = 'results'
    chemistry   = '3prime'   // Default chemistry kit: '3prime' or '5prime'

    // ── Reference files ─────────────────────────────────────────────────────────
    ref_fasta        = "/sc-projects/sc-proj-cc12-ag-romagnani/ref/hs/pacbio/GCA_000001405.15_GRCh38_no_alt_analysis_set.fna"
    ref_gtf          = "/sc-projects/sc-proj-cc12-ag-romagnani/ref/hs/pacbio/gencode.v49.annotation.sorted.gtf"

    // PacBio preprocessing references
    adapter_primers  = "${projectDir}/assets/adapters/mas16_primers.fasta"  // default: MAS16 Kinnex kit; override with --adapter_primers or per-sample adapter_kit column
    min_read_length  = 200  // minimum segment length post-Skera (bp)
    tenx_3kit_primers = "${projectDir}/assets/primers/10x_3kit_primers.fasta"
    tenx_5kit_primers = "${projectDir}/assets/primers/10x_5kit_primers.fasta"
    tenx_whitelist   = "${projectDir}/assets/barcodes/3M-3pgex-may-2023.REVCOMP.txt.xz"

    // SQANTI3 reference files
    cage_peaks       = "/sc-projects/sc-proj-cc12-ag-romagnani/ref/hs/pacbio/refTSS_v4.1_human_coordinate.hg38.sorted.bed"
    polya_list       = "/sc-projects/sc-proj-cc12-ag-romagnani/ref/hs/pacbio/mouse_and_human.polyA_motif.txt"
    polya_peak       = "/sc-projects/sc-proj-cc12-ag-romagnani/ref/hs/pacbio/atlas.clusters.2.0.GRCh38.96_chr.bed"
    intropolis       = "/sc-projects/sc-proj-cc12-ag-romagnani/ref/hs/pacbio/intropolis.v1.hg19_with_liftover_to_hg38.tsv.min_count_10.modified.sorted.tsv"

    // ── Container images ────────────────────────────────────────────────────────
    container_skera     = "quay.io/biocontainers/pbskera:1.4.0--hdfd78af_0"
    container_lima      = "quay.io/biocontainers/lima:26.2.1--h9ee0642_0"
    container_isoseq    = "quay.io/biocontainers/isoseq:4.3.0--h9ee0642_0"
    container_pbmm2     = "quay.io/biocontainers/pbmm2:26.1.0_build1"
    container_samtools  = "quay.io/biocontainers/samtools:1.23.1--ha83d96e_0"
    container_isoquant  = "quay.io/biocontainers/isoquant:3.13.0--pyh106432d_0"
    container_sqanti3   = "quay.io/biocontainers/sqanti3:6.0.1--hdfd78af_0"
    container_seqkit    = "quay.io/biocontainers/seqkit:2.13.0--he881be0_0"
    container_cramino   = "quay.io/biocontainers/cramino:0.14.5--hdbdd923_0"
    container_multiqc   = "quay.io/biocontainers/multiqc:1.34--pyhdfd78af_0"

    // MultiQC config
    multiqc_config      = "${projectDir}/assets/multiqc_config.yaml"

    // SQANTI3 chunking (Plan 03 Part B)
    sqanti_chunks       = 8
}

apptainer.enabled    = true
apptainer.autoMounts = true
apptainer.cacheDir   = '/home/knighto/bin/apptainer/cache'
process.executor     = 'slurm'

profiles {
    standard {
        process.executor = 'local'
    }

    slurm {
        process.queue          = 'compute'
        apptainer.envWhitelist = ['APPTAINER_TMPDIR', 'APPTAINER_CACHEDIR']
        apptainer.runOptions   = '--bind /charite-store-f/f-cc12-ag-romagnani,/sc-projects/sc-proj-cc12-ag-romagnani,/sc-scratch/sc-scratch-cc12-ag-romagnani,/home/knighto'

        process {
            errorStrategy = 'terminate'

            withLabel: 'process_low' {
                cpus   = 2
                memory = 8.GB
                time   = 4.h
            }
            withLabel: 'process_medium' {
                cpus   = 8
                memory = 32.GB
                time   = 12.h
            }
            withLabel: 'process_high' {
                cpus   = 16
                memory = 64.GB
                time   = 24.h
            }
            withLabel: 'process_ultra' {
                cpus   = 32
                memory = 256.GB
                time   = 48.h
            }

            // Per-process overrides
            withName: 'PBMM2_ALIGN' {
                cpus   = 16
                memory = 64.GB
                time   = 24.h
            }
            withName: 'ISOQUANT_DISCOVERY' {
                cpus   = 32
                memory = 600.GB
                time   = 48.h
            }
            withName: 'ISOQUANT_QUANTIFY' {
                cpus   = 16
                memory = 128.GB
                time   = 24.h
            }
            withName: 'SQANTI3_QC' {
                cpus   = 16
                memory = 128.GB
                time   = 24.h
            }
            withName: 'SQANTI3_FILTER' {
                cpus   = 8
                memory = 32.GB
                time   = 4.h
            }
            withName: 'CRAMINO' {
                cpus   = 4
                memory = 8.GB
                time   = 4.h
            }

            // Plan 03: IsoQuant sharding + SQANTI3 chunking
            withName: 'SPLIT_BAM_BY_SHARD' {
                cpus   = 4
                memory = 8.GB
                time   = 2.h
            }
            withName: 'ISOQUANT_DISCOVERY_SHARD' {
                cpus   = 16
                memory = 128.GB   // monitor chr1 shard; increase to 256 GB if OOM
                time   = 12.h
            }
            withName: 'MERGE_SHARD_GTFS' {
                cpus   = 2
                memory = 16.GB
                time   = 1.h
            }
            withName: 'SQANTI3_SPLIT_GTF' {
                cpus   = 2
                memory = 8.GB
                time   = 30.m
            }
            withName: 'SQANTI3_QC_CHUNK' {
                cpus   = 8
                memory = 64.GB
                time   = 6.h
            }
            withName: 'SQANTI3_MERGE_CHUNKS' {
                cpus   = 2
                memory = 16.GB
                time   = 30.m
            }
        }
    }
}
